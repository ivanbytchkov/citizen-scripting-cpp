#!/bin/bash
set -euo pipefail

SERVER_DIR="${FX_SERVER_DIR:?Set FX_SERVER_DIR to your cfx-server directory}"
RESOURCE_DIR="${FX_RESOURCE_DIR:?Set FX_RESOURCE_DIR to your resource directory}"
PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
BUILD_DIR="$PROJECT_DIR/build"

cd "$PROJECT_DIR"

rm -rf "$BUILD_DIR"

python3 tools/native_db.py

premake5 --os=linux gmake
make -C "$BUILD_DIR" -f citizen-scripting-cpp.make config=release \
        CC="zig cc -target x86_64-linux-musl" \
        CXX="zig c++ -target x86_64-linux-musl" \
        -j"$(getconf _NPROCESSORS_ONLN 2>/dev/null || nproc 2>/dev/null || echo 4)" \
        2> >(grep -v "unable to open library directory '/usr/lib64'" >&2 || true)

tools/build tools/example/server.cpp

cp "$BUILD_DIR/bin/Release/libcitizen-scripting-cpp.so" "$SERVER_DIR/"

rm -rf "$RESOURCE_DIR"
mkdir -p "$RESOURCE_DIR"
cp tools/example/server.wasm "$RESOURCE_DIR/server.wasm"
cp tools/example/fxmanifest.lua "$RESOURCE_DIR/fxmanifest.lua"

rm -f tools/example/server.wasm

echo "Done. Runtime -> $SERVER_DIR, resource -> $RESOURCE_DIR"
